PORT=8078
NODE_ENV=development

# i18n — kamanilan tek dil (TR)
APP_LOCALES=tr
DEFAULT_LOCALE=tr

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=x_ilan

# Dev login (sadece gelistirme)
ALLOW_TEMP_LOGIN=1
TEMP_PASSWORD=change-me

# Auth
JWT_SECRET=change-me-to-a-long-random-hex
COOKIE_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:3000,http://localhost:3003,http://localhost:3002

# Storage
# - cloudinary: Cloudinary kullan
# - local     : sunucu dosya sistemi (LOCAL_STORAGE_ROOT) kullan
STORAGE_DRIVER=cloudinary

# Cloudinary (STORAGE_DRIVER=cloudinary iken)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=uploads
CLOUDINARY_UNSIGNED_PRESET=

# Local storage (STORAGE_DRIVER=local iken)
LOCAL_STORAGE_ROOT=
LOCAL_STORAGE_BASE_URL=/uploads

# Public URLs
PUBLIC_URL=http://localhost:8078
PUBLIC_API_BASE=http://localhost:8078
BACKEND_URL=http://localhost:8078
FRONTEND_URL=http://localhost:3003

# Seed / admin kullanici
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Test customer
CUSTOMER_EMAIL=musteri@example.com
CUSTOMER_PASSWORD=change-me
CUSTOMER_ID=

# SMTP (opsiyonel)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
GMAIL=

# Google OAuth (opsiyonel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (opsiyonel)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# AI Support (opsiyonel)
AI_SUPPORT_ENABLED=0
AI_PROVIDER_ORDER=grok,openai,anthropic
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI=
CLAUDE=

# Iyzico
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_MARKETPLACE_MODE=true
IYZICO_TEST_MODE=true
IYZICO_SUB_MERCHANT_KEY=
IYZICO_STORE_SUB_MERCHANT_KEYS={}
